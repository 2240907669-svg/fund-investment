      "label": "official_primary",
      "sources": [
        "新华社",
        "人民日报",
        "中国政府网",
        "外交部",
        "国家发展改革委",
        "工业和信息化部",
        "科技部",
        "中国人民银行",
        "中国证监会",
        "国家统计局",
        "上海证券交易所",
        "深圳证券交易所",
        "地方政府新闻发布平台",
        "基金公司公告"
      ]
    },
    {
      "tier": 2,
      "label": "institutional_primary",
      "sources": [
        "券商及资产管理机构官网研究",
        "上市公司公告与投资者关系材料",
        "交易所行情与基金份额数据",
