        "路透社",
        "彭博",
        "AP"
      ]
    },
    {
      "tier": 4,
      "label": "lead_only",
      "sources": [
        "行情软件资讯",
        "社交媒体",
        "论坛与自媒体",
        "转载聚合站"
      ],
      "rule": "May generate a lead but cannot by itself raise verification_status above unverified."
    }
  ],
  "requiredFields": [
    "first_published_at",
    "event_start",
    "verification_status",
    "confidence",
    "novelty",
    "beneficiary_chain",
    "portfolio_mapping",
    "priced_in_status",
    "validation_signals",
    "invalidation_signals",
    "next_checkpoint"
